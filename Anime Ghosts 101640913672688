local function safeLoop(interval, func)
    local thread = task.spawn(function()
        while getgenv().EnzoScriptLoaded do
            local ok, err = pcall(func)
            if not ok then warn("[ENZO] " .. tostring(err)) end
            task.wait(interval)
        end
    end)
    table.insert(getgenv().EnzoThreads, thread)
    return thread
end

