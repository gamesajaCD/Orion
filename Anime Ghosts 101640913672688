local function buildToggleUI(variantKey)
    if getgenv().ToggleUIInstance then
        pcall(function() getgenv().ToggleUIInstance:Destroy() end)
        getgenv().ToggleUIInstance = nil
    end

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "ToggleUI_Enzo"
    ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    ScreenGui.ResetOnSpawn = false
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    getgenv().ToggleUIInstance = ScreenGui

    local Container = Instance.new("Frame")
    Container.Name = "Container"; Container.Parent = ScreenGui
    Container.Position = UDim2.new(0,10,0.45,0)
    Container.Size = UDim2.new(0,64,0,64)
    Container.BackgroundTransparency = 1; Container.Active = true

    local ToggleBtn = Instance.new("TextButton")
    ToggleBtn.Parent = Container
    ToggleBtn.AnchorPoint = Vector2.new(0.5,0.5)
    ToggleBtn.Position = UDim2.new(0.5,0,0.5,0)
    ToggleBtn.Size = UDim2.new(1.1,0,1.1,0)
    ToggleBtn.BackgroundTransparency = 1; ToggleBtn.Text = ""; ToggleBtn.ZIndex = 10

    local dragging,dragInput,dragStart,startPos,hasDragged = false,nil,nil,nil,false
    ToggleBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging=true; hasDragged=false; dragStart=input.Position; startPos=Container.Position
            input.Changed:Connect(function() if input.UserInputState==Enum.UserInputState.End then dragging=false end end)
        end
    end)
    ToggleBtn.InputChanged:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch then dragInput=input end
    end)
    local dc = UserInputService.InputChanged:Connect(function(input)
        if input==dragInput and dragging then
            local d=input.Position-dragStart; if d.Magnitude>5 then hasDragged=true end
            Container.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+d.X,startPos.Y.Scale,startPos.Y.Offset+d.Y)
        end
    end)
    table.insert(getgenv().EnzoConnections, dc)

    local function doToggle()
        VirtualInputManager:SendKeyEvent(true,Enum.KeyCode.LeftControl,false,game)
        task.wait(0.05)
        VirtualInputManager:SendKeyEvent(false,Enum.KeyCode.LeftControl,false,game)
    end

    local function makeCircle(parent,size,color,transp)
        local f=Instance.new("Frame"); f.Parent=parent
        f.AnchorPoint=Vector2.new(0.5,0.5); f.Position=UDim2.new(0.5,0,0.5,0)
        f.Size=UDim2.new(size,0,size,0)
        f.BackgroundColor3=color or Color3.fromRGB(20,20,20)
        f.BackgroundTransparency=transp or 0; f.BorderSizePixel=0
        Instance.new("UICorner",f).CornerRadius=UDim.new(1,0)
        return f
    end

    local function makeStroke(parent,color,thickness)
        local s=Instance.new("UIStroke"); s.Parent=parent
        s.Color=color or Color3.fromRGB(255,255,255); s.Thickness=thickness or 2
        return s
    end

    local function makeIcon(parent,color,size,zi)
