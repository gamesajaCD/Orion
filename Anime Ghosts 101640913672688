                    if t then Fluent:Notify({Title="Auto Farm",Content="Target: "..t.Text.." ("..i.."/"..#allEnemies..")",Duration=2}) end
                end
            end)

            moveToByMethod(ePos, method)
            if not Options.AutoFarm.Value then stopMovement(); pcall(function() if deathConn then deathConn:Disconnect() end end); break end

            local attackStart = tick()
            while getgenv().EnzoScriptLoaded and Options.AutoFarm.Value do
                if enemyDied then break end
                local pOk = pcall(function() return currentEnemy.Parent end)
