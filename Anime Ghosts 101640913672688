task.spawn(function()
    table.insert(getgenv().EnzoThreads, coroutine.running())
    while getgenv().EnzoScriptLoaded do
        if not Options.AutoFarm.Value then task.wait(0.3); continue end
        local sel = Options.EnemyDropdown.Value
        local method = Options.MethodDropdown.Value or "Teleport"
        if not sel or type(sel) ~= "table" then task.wait(0.5); continue end

        local selNames = {}
        for name, on in pairs(sel) do if on and name ~= "No Enemies Found" then table.insert(selNames, name) end end
        if #selNames == 0 then task.wait(0.5); continue end

        local allEnemies = {}
        for _, en in ipairs(selNames) do
