-- [[ SMART MOVEMENT ]] --
-- ========================================
local BYPASS_SPEED = 200
local STUCK_CHECK_INTERVAL = 0.5
local STUCK_THRESHOLD = 2
local MAX_STUCK_COUNT = 5

local function cleanOurMovers()
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        for _, part in pairs(char:GetDescendants()) do
            if part.Name == "EnzoVelocity" or part.Name == "EnzoGyro" then
                pcall(function() part:Destroy() end)
            end
        end
    end)
end

local function isFarmActive()
    if not getgenv().EnzoScriptLoaded then return false end
    local farmOn = Options.AutoFarm and Options.AutoFarm.Value or false
    local questOn = Options.AutoQuest and Options.AutoQuest.Value or false
    return farmOn or questOn
end

local function stopMovement()
    cleanOurMovers()
    pcall(function()
        local _, hrp, hum = getCharacter()
        if hrp then
            hrp.Velocity = Vector3.new(0,0,0)
            hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
        end
        if hum and hrp then hum:MoveTo(hrp.Position) end
    end)
end

local function findAlternativePosition(currentPos, targetPos, attempt)
    local direction = (targetPos - currentPos).Unit
    local right = direction:Cross(Vector3.new(0,1,0)).Unit
    local up = Vector3.new(0,1,0)
    local offsets = {
        right*30, right*-30, up*30, right*30+up*20,
        right*-30+up*20, direction*-15+right*40,
        direction*-15+right*-40, up*50
    }
    return currentPos + offsets[((attempt-1)%#offsets)+1]
end

local function smartFlyTo(targetPosition, speed)
    local char, hrp = getCharacter()
    if not hrp then return false end
    local targetPos = targetPosition + Vector3.new(0,3,0)
    local flySpeed = speed or BYPASS_SPEED
    cleanOurMovers()

    local bv = Instance.new("BodyVelocity")
    bv.Name = "EnzoVelocity"
    bv.MaxForce = Vector3.new(math.huge,math.huge,math.huge)
    bv.Velocity = Vector3.new(0,0,0)
    bv.Parent = hrp
    table.insert(getgenv().EnzoBodyMovers, bv)

    local bg = Instance.new("BodyGyro")
    bg.Name = "EnzoGyro"
    bg.MaxTorque = Vector3.new(math.huge,math.huge,math.huge)
    bg.D = 100; bg.P = 10000
    bg.Parent = hrp
    table.insert(getgenv().EnzoBodyMovers, bg)

    local startTime = tick()
    local arrived = false
    local lastPos = hrp.Position
    local lastCheckTime = tick()
    local stuckCount = 0
    local currentTarget = targetPos
    local isRerouting = false
    local rerouteTarget = nil

    while getgenv().EnzoScriptLoaded and isFarmActive() do
        char, hrp = getCharacter()
        if not hrp then break end
        if (tick()-startTime) > 40 then break end
        if not bv or not bv.Parent then break end

        local currentPos = hrp.Position
        if (targetPos-currentPos).Magnitude < 5 then arrived = true; break end

        if (tick()-lastCheckTime) >= STUCK_CHECK_INTERVAL then
            local movedDist = (currentPos-lastPos).Magnitude
            if movedDist < STUCK_THRESHOLD then
                stuckCount = stuckCount + 1
                if stuckCount >= MAX_STUCK_COUNT then break end
                isRerouting = true
                rerouteTarget = findAlternativePosition(currentPos, targetPos, stuckCount)
            else
                if isRerouting and rerouteTarget then
                    if (rerouteTarget-currentPos).Magnitude < 10 then
                        isRerouting = false; rerouteTarget = nil
                        stuckCount = math.max(0,stuckCount-1)
                    end
                else
                    stuckCount = math.max(0,stuckCount-1)
                end
            end
            lastPos = currentPos; lastCheckTime = tick()
        end

        currentTarget = (isRerouting and rerouteTarget) and rerouteTarget or targetPos
        local direction = (currentTarget-currentPos)
        local dist = direction.Magnitude
        if dist > 0.5 then
            local moveDir = direction.Unit
            local actualSpeed = math.min(flySpeed, dist*3)
            if stuckCount >= 2 then
                moveDir = (moveDir + Vector3.new(0,0.5,0)).Unit
                actualSpeed = flySpeed * 0.8
            end
            bv.Velocity = moveDir * actualSpeed
            bg.CFrame = CFrame.lookAt(currentPos, Vector3.new(currentTarget.X, currentPos.Y, currentTarget.Z))
        end
        RunService.Heartbeat:Wait()
    end

    cleanOurMovers()
    pcall(function()
        _, hrp = getCharacter()
        if hrp then hrp.Velocity = Vector3.new(0,0,0); hrp.AssemblyLinearVelocity = Vector3.new(0,0,0) end
    end)
    return arrived
end

local function smartWalkTo(targetPosition)
    local char, hrp, hum = getCharacter()
    if not hum or not hrp then return false end
    hum:MoveTo(targetPosition)
    local startTime = tick()
    local lastRepath = tick()
    local lastPos = hrp.Position
    local lastStuckCheck = tick()
    local stuckCount = 0

    while getgenv().EnzoScriptLoaded and isFarmActive() do
        char, hrp, hum = getCharacter()
        if not hrp or not hum then return false end
        if (hrp.Position-targetPosition).Magnitude < 8 then return true end
        if (tick()-startTime) > 60 then return false end

        if (tick()-lastRepath) > 1 then hum:MoveTo(targetPosition); lastRepath = tick() end

        if (tick()-lastStuckCheck) >= STUCK_CHECK_INTERVAL then
            if (hrp.Position-lastPos).Magnitude < STUCK_THRESHOLD then
                stuckCount = stuckCount + 1
                if stuckCount >= 2 then pcall(function() hum.Jump = true end) end
                if stuckCount >= 4 then
                    hum:MoveTo(findAlternativePosition(hrp.Position, targetPosition, stuckCount))
                    lastRepath = tick() + 2; stuckCount = 0
                end
            else
                stuckCount = math.max(0,stuckCount-1)
            end
            lastPos = hrp.Position; lastStuckCheck = tick()
        end
        task.wait(0.1)
    end
    pcall(function() _, hrp, hum = getCharacter(); if hum and hrp then hum:MoveTo(hrp.Position) end end)
    return false
end

local function moveToByMethod(position, method)
    if not position or not getgenv().EnzoScriptLoaded or not isFarmActive() then return false end
    if method == "Teleport" then return smartFlyTo(position, BYPASS_SPEED)
    elseif method == "Tween" then return smartFlyTo(position, 100)
    elseif method == "Walk" then return smartWalkTo(position)
    else return smartFlyTo(position, BYPASS_SPEED) end
end

local function stayNearEnemy(enemyModel, method)
    if not isFarmActive() then cleanOurMovers(); return false end
    local enemyPos = nil
    pcall(function()
        if enemyModel.Parent then
            local part = enemyModel:FindFirstChildWhichIsA("BasePart")
            if part then enemyPos = part.Position end
        end
    end)
    if not enemyPos then return false end
    local _, hrp = getCharacter()
    if not hrp then return false end
    local dist = (hrp.Position-enemyPos).Magnitude
    if dist > 12 then
        if method == "Walk" then
            local _,_,hum = getCharacter(); if hum then hum:MoveTo(enemyPos) end
        else
            cleanOurMovers()
            local bv = Instance.new("BodyVelocity")
            bv.Name = "EnzoVelocity"; bv.MaxForce = Vector3.new(math.huge,math.huge,math.huge)
            local dir = (enemyPos+Vector3.new(0,3,0)-hrp.Position)
            local dirUnit = dir.Unit
            if dist > 30 then dirUnit = (dirUnit+Vector3.new(0,0.3,0)).Unit end
            bv.Velocity = dirUnit * math.min(dist*5, 200)
            bv.Parent = hrp; table.insert(getgenv().EnzoBodyMovers, bv)
            task.wait(0.15); cleanOurMovers()
            pcall(function() hrp.Velocity = Vector3.new(0,0,0); hrp.AssemblyLinearVelocity = Vector3.new(0,0,0) end)
        end
    end
    return true
end

