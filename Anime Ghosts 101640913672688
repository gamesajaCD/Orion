local function parseQuestText(text)
    if not text or text == "" then return nil end
    local en, cur, mx = text:match("Defeat%s+(.+)%s+%[(%d+)/(%d+)%]")
    if en and cur and mx then
        return {name=en:match("^%s*(.-)%s*$"), current=tonumber(cur), max=tonumber(mx), raw=text}
    end
    return nil
end

local function getActiveQuests()
    local quests = {}
    pcall(function()
        local sg = LocalPlayer.PlayerGui:FindFirstChild("SideGUI")
        if not sg then return end
        local c = sg:FindFirstChild("Content")
        if not c then return end
        local qf = c:FindFirstChild("ActiveQuest")
        if not qf then return end
        for _, child in pairs(qf:GetDescendants()) do
            if child:IsA("TextLabel") then
                local parsed = parseQuestText(child.ContentText or child.Text or "")
                if parsed then table.insert(quests, parsed) end
            end
        end
    end)
    return quests
end

local function isQuestComplete(qd) return qd.current >= qd.max end

local function getQuestProgress(en)
    for _, q in ipairs(getActiveQuests()) do if q.name == en then return q end end
    return nil
end

