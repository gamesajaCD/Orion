        for i, currentEnemy in ipairs(allEnemies) do
            if not getgenv().EnzoScriptLoaded or not Options.AutoFarm.Value then stopMovement(); break end
            if not isModelAlive(currentEnemy) then continue end

            local ePos = getEnemyPosition(currentEnemy)
            local uid = getEnemyUniqueId(currentEnemy)
            if not ePos or not uid then continue end

            local enemyDied = false
            local deathConn = nil
            pcall(function()
                deathConn = currentEnemy.AncestryChanged:Connect(function(_, np)
                    if np == nil then enemyDied = true end
                end)
            end)

            pcall(function()
