-- Fungsi untuk scan semua enemies di workspace.Server.Enemies.World
local function GetAllEnemies()
    local enemies = {}
    local worldFolder = workspace:FindFirstChild("Server")
        and workspace.Server:FindFirstChild("Enemies")
        and workspace.Server.Enemies:FindFirstChild("World")

    if not worldFolder then
        return enemies
    end

    local function ScanFolder(folder)
        for _, child in ipairs(folder:GetChildren()) do
            if child:IsA("BasePart") then
                local id = nil
                local health = nil

                pcall(function()
                    id = child:GetAttribute("ID")
                end)
                pcall(function()
                    health = child:GetAttribute("Health")
                end)

                if id and health ~= nil then
                    table.insert(enemies, {
                        Name = child.Name,
                        Part = child,
                        ID = id,
                        Health = health
                    })
                end
            end

            if #child:GetChildren() > 0 then
                ScanFolder(child)
            end
        end
    end

    ScanFolder(worldFolder)
    return enemies
end

-- Fungsi untuk mendapatkan list nama enemies (tanpa duplikat)
local function GetEnemyNames()
    local enemies = GetAllEnemies()
    local names = {}
    local added = {}

    for _, enemy in ipairs(enemies) do
        if not added[enemy.Name] then
            table.insert(names, enemy.Name)
            added[enemy.Name] = true
        end
    end

    if #names == 0 then
        table.insert(names, "No Enemies Found")
    end

    return names
end

-- Fungsi teleport player ke posisi enemy
local function TeleportTo(position)
    local character = LocalPlayer.Character
    if character and character:FindFirstChild("HumanoidRootPart") then
        character.HumanoidRootPart.CFrame = CFrame.new(position + Vector3.new(0, 3, 0))
    end
end

-- Fungsi untuk attack enemy berdasarkan ID
local function AttackEnemy(enemyID)
    local args = {
