-- Loop Auto Farm
task.spawn(function()
    while true do
        if autoFarmEnabled and #selectedEnemies > 0 then
            local allEnemies = GetAllEnemies()

            -- Filter enemies berdasarkan yang dipilih di dropdown
            local targetEnemies = {}
            for _, enemy in ipairs(allEnemies) do
                for _, selectedName in ipairs(selectedEnemies) do
                    if enemy.Name == selectedName then
                        -- Cek apakah masih hidup
                        local currentHealth = nil
                        pcall(function()
                            currentHealth = enemy.Part:GetAttribute("Health")
                        end)

                        if currentHealth and currentHealth > 0 then
                            table.insert(targetEnemies, enemy)
                        end
                        break
                    end
                end
            end

            -- Farm enemies satu per satu
            for _, enemy in ipairs(targetEnemies) do
                if not autoFarmEnabled then break end

                -- Cek ulang health sebelum teleport
                local currentHealth = nil
                pcall(function()
                    currentHealth = enemy.Part:GetAttribute("Health")
                end)

                if currentHealth and currentHealth > 0 and enemy.Part.Parent then
                    -- Teleport ke enemy
                    TeleportTo(enemy.Part.Position)
                    task.wait(0.3)

                    -- Attack sampai health 0
                    while autoFarmEnabled do
                        local hp = nil
                        pcall(function()
                            hp = enemy.Part:GetAttribute("Health")
                        end)

                        -- Jika enemy mati atau hilang, lanjut ke berikutnya
                        if not hp or hp <= 0 or not enemy.Part.Parent then
                            break
                        end

                        -- Attack enemy
                        AttackEnemy(enemy.ID)
                        task.wait(0.01)
                    end

                    task.wait(0.2)
                end
            end
        end
        task.wait(0.1)
    end
end)  
