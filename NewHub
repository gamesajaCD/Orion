local PlaceId = game.PlaceId

-- Fungsi untuk load script dari github
local function LoadScript(fileName)
    local url = "https://raw.githubusercontent.com/gamesajaCD/Orion/refs/heads/main/NewHub"
    local success, result = pcall(function()
        return loadstring(game:HttpGet(url))()
    end)
    
    if not success then
        warn("Gagal memuat script: " .. fileName .. " | Error: " .. result)
    end
end

